import { NextResponse } from 'next/server';

export async function POST(request) {
  try {
    const { email, password } = await request.json();

    // 1. Generar el Access Token del cliente
    const loginQuery = `
      mutation customerAccessTokenCreate($input: CustomerAccessTokenCreateInput!) {
        customerAccessTokenCreate(input: $input) {
          customerAccessToken {
            accessToken
          }
          customerUserErrors {
            message
          }
        }
      }
    `;

    const loginRes = await fetch(`https://${process.env.NEXT_PUBLIC_SHOPIFY_STORE_DOMAIN}/api/2024-01/graphql.json`, {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'X-Shopify-Storefront-Access-Token': process.env.NEXT_PUBLIC_SHOPIFY_STOREFRONT_ACCESS_TOKEN,
      },
      body: JSON.stringify({ 
        query: loginQuery, 
        variables: { input: { email, password } } 
      }),
    });

    const loginJson = await loginRes.json();
    const errors = loginJson.data?.customerAccessTokenCreate?.customerUserErrors;

    if (errors?.length > 0) {
      return NextResponse.json({ error: "Credenciales incorrectas" }, { status: 401 });
    }

    const token = loginJson.data?.customerAccessTokenCreate?.customerAccessToken?.accessToken;

    if (!token) {
      return NextResponse.json({ error: "Error al iniciar sesión" }, { status: 401 });
    }

    // 2. Usar el token para obtener los datos del cliente y enviarlos a KolmaRD
    const customerQuery = `
      query customerInfo($customerAccessToken: String!) {
        customer(customerAccessToken: $customerAccessToken) {
          id
          firstName
          email
          phone
          defaultAddress {
            address1
          }
        }
      }
    `;

    const customerRes = await fetch(`https://${process.env.NEXT_PUBLIC_SHOPIFY_STORE_DOMAIN}/api/2024-01/graphql.json`, {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'X-Shopify-Storefront-Access-Token': process.env.NEXT_PUBLIC_SHOPIFY_STOREFRONT_ACCESS_TOKEN,
      },
      body: JSON.stringify({ 
        query: customerQuery, 
        variables: { customerAccessToken: token } 
      }),
    });

    const customerJson = await customerRes.json();
    const customer = customerJson.data?.customer;

    if (!customer) {
      return NextResponse.json({ error: "No se pudieron obtener los datos del usuario" }, { status: 400 });
    }

    return NextResponse.json({ 
      success: true, 
      user: {
        id: customer.id,
        email: customer.email,
        firstName: customer.firstName || "Usuario",
        phone: customer.phone,
        address: customer.defaultAddress?.address1 || "Centro",
        token: token // Se guarda el token para futuras operaciones si las necesitas
      }
    });

  } catch (error) {
    return NextResponse.json({ error: "Error de conexión con Shopify" }, { status: 500 });
  }
}
